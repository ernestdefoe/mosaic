{
    "name": "ernestdefoe/mosaic",
    "description": "Mosaic — a polished, configurable Flarum 2 theme with a tiled hero, category grid, sidebar widgets, and optional integrations for support tickets (linkrobins/support) and a marketplace storefront (ramon/marketplace).",
    "keywords": [
        "flarum",
        "flarum-extension",
        "theme",
        "mosaic"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Ernest Defoe",
            "email": "ernestdefoe@gmail.com",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/ernestdefoe/mosaic/issues",
        "source": "https://github.com/ernestdefoe/mosaic"
    },
    "require": {
        "flarum/core": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ernestdefoe\\Mosaic\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Mosaic",
            "category": "theme",
            "icon": {
                "name": "fas fa-shapes",
                "backgroundColor": "#2563eb",
                "color": "#ffffff"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
