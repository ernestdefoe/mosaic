{
  "extends": "flarum-tsconfig",
  "include": [
    "src/**/*",
    "forum.ts",
    "admin.ts",
    "../vendor/flarum/core/js/dist-typings/@types/**/*.d.ts"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "flarum/*": ["../vendor/flarum/core/js/dist-typings/*"]
    },
    "types": ["mithril", "jquery"]
  }
}
